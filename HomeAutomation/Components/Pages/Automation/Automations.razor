    private void ToggleSetValue(HashSet<int> ids, int id, bool selected)
    {
        if (selected)
            ids.Add(id);
        else
            ids.Remove(id);
    }

    private bool TryParseTime(string? value, out TimeOnly? time)
    {
        time = null;
        if (string.IsNullOrWhiteSpace(value))
            return true;

        if (TimeOnly.TryParse(value, out var parsed))
        {
            time = parsed;
            return true;
        }

        snackbar.Add($"Invalid time value '{value}'. Use HH:mm.", Severity.Error);
        return false;
    }

    private bool TryParseJsonDictionary(string? json, out Dictionary<string, string>? result)
    {
        result = null;
        if (string.IsNullOrWhiteSpace(json))
            return true;

        try
        {
            result = JsonSerializer.Deserialize<Dictionary<string, string>>(json);
            return result is not null;
        }
        catch (JsonException)
        {
            snackbar.Add("Device event properties must be valid JSON object (string->string).", Severity.Error);
            return false;
        }
    }

    private async Task<bool> ConfirmDeleteAsync(string message)
    {
        try
        {
            return await jsRuntime.InvokeAsync<bool>("confirm", message);
        }
        catch
        {
            return false;
        }
    }

    private static string? NormalizeNullable(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

